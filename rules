  <script src="site.js"></script>
  <script>
    // Video background, force play immediately, fade in on first frame
    (function () {
      var v = document.getElementById('heroBgVideo');
      if (!v) return;
      var tryPlay = function () { v.play().catch(function () {}); };
      tryPlay();
      v.addEventListener('canplay', tryPlay, { once: true });
      v.addEventListener('playing', function () { v.classList.add('loaded'); }, { once: true });
      document.addEventListener('visibilitychange', function () {
        if (!document.hidden) v.play().catch(function () {});
      });
    })();

    // Collapsible sections
    document.querySelectorAll('.section-header').forEach(function (header) {
      header.addEventListener('click', function (e) {
        if (e.target.closest('a')) return;
        header.closest('.rule-section').classList.toggle('collapsed');
      });
    });

    // ---- Rule search ----
    var input = document.getElementById('ruleSearch');
    var countEl = document.getElementById('ruleCount');
    var clearBtn = document.getElementById('searchClear');
    var noResults = document.getElementById('noResults');
    var rules = Array.from(document.querySelectorAll('.rule'));
    var sections = Array.from(document.querySelectorAll('.rule-section'));
    var originals = new Map(rules.map(function (r) { return [r, r.querySelector('.rule-text').innerHTML]; }));
    var TOTAL = rules.length;

    function escRe(s) { return s.replace(/[.*+?^${}()|[\]\\]/g, '\\$&'); }

    function filterRules() {
      var q = input.value.trim();
      var ql = q.toLowerCase();
      var visible = 0;
      rules.forEach(function (rule) {
        var rt = rule.querySelector('.rule-text');
        rt.innerHTML = originals.get(rule);
        var tag = rule.querySelector('.tag').textContent;
        var text = (tag + ' ' + rt.textContent).toLowerCase();
        var match = !ql || text.includes(ql);
        rule.classList.toggle('no-match', !match);
        if (match) {
          visible++;
          if (ql) {
            var re = new RegExp('(' + escRe(q) + ')', 'gi');
            rt.innerHTML = rt.innerHTML.replace(re, '<mark>$1</mark>');
          }
        }
      });
      var sectVisible = 0;
      sections.forEach(function (sec) {
        var has = Array.from(sec.querySelectorAll('.rule')).some(function (r) { return !r.classList.contains('no-match'); });
        sec.classList.toggle('no-match', !has);
        if (has) {
          sectVisible++;
          if (ql) sec.classList.remove('collapsed');
        }
      });
      noResults.classList.toggle('show', sectVisible === 0 && ql.length > 0);
      clearBtn.style.display = ql ? 'block' : 'none';
      countEl.textContent = ql
        ? visible + ' matching rule' + (visible === 1 ? '' : 's') + ' for "' + q + '"'
        : 'Showing all ' + TOTAL + ' rules';
    }

    input.addEventListener('input', filterRules);
    clearBtn.addEventListener('click', function () { input.value = ''; filterRules(); input.focus(); });
    var clearLink = document.getElementById('clearSearch');
    if (clearLink) clearLink.addEventListener('click', function (e) { e.preventDefault(); input.value = ''; filterRules(); });

    // ---- Sidebar active section on scroll ----
    // Tracks scroll position directly so the highlighted sidebar link always
    // matches the section actually under the reading line (just below the
    // fixed nav), instead of relying on IntersectionObserver enter/exit
    // events, which can desync on short sections or fast scrolling.
    var sideLinks = Array.from(document.querySelectorAll('.sidebar-link[href^="#"]'));
    var sectionEls = Array.from(document.querySelectorAll('.rule-section[id]'));
    var READ_LINE = 110; // px from top of viewport; just under the fixed nav

    function setActiveLink(id) {
      sideLinks.forEach(function (a) {
        a.classList.toggle('active', a.getAttribute('href') === '#' + id);
      });
    }

    function updateActiveSection() {
      if (!sectionEls.length) return;
      var current = sectionEls[0];
      for (var i = 0; i < sectionEls.length; i++) {
        var rect = sectionEls[i].getBoundingClientRect();
        if (rect.top - READ_LINE <= 0) {
          current = sectionEls[i];
        } else {
          break;
        }
      }
      var atBottom = window.innerHeight + window.scrollY >= document.documentElement.scrollHeight - 4;
      if (atBottom) current = sectionEls[sectionEls.length - 1];
      setActiveLink(current.id);
    }

    var scrollTicking = false;
    window.addEventListener('scroll', function () {
      if (scrollTicking) return;
      scrollTicking = true;
      requestAnimationFrame(function () { updateActiveSection(); scrollTicking = false; });
    }, { passive: true });
    window.addEventListener('resize', updateActiveSection);
    updateActiveSection();

    // ---- Typewriter placeholder for common searches ----
    (function () {
      if (!input) return;
      var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      var terms = ['RDM', 'VDM', 'metagaming', 'powergaming', 'new life rule', 'kill or rob', 'hostage rules', 'green zones', 'combat logging', 'VYL', 'fail RP', 'gang taxing'];
      var base = 'Search rules: ';
      var ti = 0, ci = 0, deleting = false, timer = null, active = false;

      function frame() {
        if (!active) return;
        var term = terms[ti];
        ci += deleting ? -1 : 1;
        input.setAttribute('placeholder', base + term.slice(0, ci));
        if (!deleting && ci === term.length) { deleting = true; return schedule(1600); }
        if (deleting && ci === 0) { deleting = false; ti = (ti + 1) % terms.length; return schedule(350); }
        schedule(deleting ? 45 : 80);
      }
      function schedule(ms) { timer = setTimeout(frame, ms); }
      function stop() { active = false; clearTimeout(timer); }
      function start() {
        if (reduce) { input.setAttribute('placeholder', 'Search rules'); return; }
        active = true; clearTimeout(timer); ti = 0; ci = 0; deleting = false; schedule(500);
      }

      input.addEventListener('focus', function () { stop(); input.setAttribute('placeholder', 'Search rules'); });
      input.addEventListener('blur', function () { if (!input.value) start(); });
      input.addEventListener('input', stop);
      start();
    })();

    filterRules();
  </script>
</body>
</html>
